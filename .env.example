# Discord
DISCORD_TOKEN=your_discord_bot_token_here

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service_account.json   # atau paste JSON string-nya langsung
SPREADSHEET_ID=your_google_spreadsheet_id_here
SHEET_NAME=Sheet1   # nama tab sheet-nya

# GitHub
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=username/repo-name   # contoh: myorg/myrepo
GITHUB_POLL_INTERVAL=300   # detik, default 5 menit

# Channels (isi dengan channel ID Discord)
GITHUB_NOTIF_CHANNEL_ID=123456789
